<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>ai.hypergraph.tidyparse</id>
    <name>Tidyparse</name>
    <vendor>Hypergraph.ai</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.python</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <typedHandler implementation="ai.hypergraph.tidyparse.TidyKeyHandler"/>
        <backspaceHandlerDelegate implementation="ai.hypergraph.tidyparse.TidyBackspaceHandler"/>
        <toolWindow id="Tidyparse" secondary="true" icon="AllIcons.Actions.EditSource" anchor="right"
                    factoryClass="ai.hypergraph.tidyparse.TidyToolWindowFactory"/>
        <completion.contributor language="any" order="first"
                implementationClass="ai.hypergraph.tidyparse.TidyCompletionContributor"/>
        <highlightVisitor implementation="ai.hypergraph.tidyparse.TidyHighlightVisitor"/>
        <postStartupActivity implementation="ai.hypergraph.tidyparse.TidyKotlinArgumentCompletionDiagnosticsStartupActivity"/>
        <fileType
                name="Tidy File"
                implementationClass="ai.hypergraph.tidyparse.TidyFileType"
                extensions="tidy"/>
        <notificationGroup id="TidyParse" displayType="BALLOON"/>
        <projectService serviceImplementation="ai.hypergraph.tidyparse.WGPURepairService"/>
    </extensions>
    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>
    <actions>
        <action id="TidyParse.WebGpuCompletion"
                class="ai.hypergraph.tidyparse.TidyRepairAction"
                text="TidyParse Python Repair"
                description="Show WebGPU Python repairs for the current line">
            <keyboard-shortcut keymap="$default" first-keystroke="control shift R"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action id="TidyParse.KotlinArgumentCompletion"
                class="ai.hypergraph.tidyparse.TidyKotlinArgumentCompletionAction"
                text="TidyParse Kotlin Argument Completion"
                description="Show well-typed Kotlin argument expressions for the current call slot">
            <keyboard-shortcut keymap="$default" first-keystroke="control shift P"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
